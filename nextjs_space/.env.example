# Dashboard - Google Cloud Run deployment

# NextAuth
NEXTAUTH_URL=https://your-dashboard-url.run.app
NEXTAUTH_SECRET=your-secret-here

# Google SSO (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Firebase / Firestore
# Set GOOGLE_APPLICATION_CREDENTIALS to the service account JSON path,
# OR rely on Cloud Run's default service account (recommended)
GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# Health check
HEARTBEAT_TOKEN=your-heartbeat-secret

# Resend (email replies)
RESEND_API_KEY=your-resend-key
