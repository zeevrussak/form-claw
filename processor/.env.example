# Processor - Google Cloud Run deployment

# Google AI Studio (Gemini)
GEMINI_API_KEY=your-gemini-api-key

# Resend (email replies)
RESEND_API_KEY=your-resend-key

# Google Cloud
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GCS_BUCKET=formclaw-assets

# Webhook security
WEBHOOK_SECRET=your-webhook-secret

# Dashboard heartbeat
HEARTBEAT_URL=https://your-dashboard-url.run.app/api/health/heartbeat
HEARTBEAT_TOKEN=your-heartbeat-secret
